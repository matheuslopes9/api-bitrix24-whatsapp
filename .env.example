# ─── Servidor ───────────────────────────────────────────────────────────────
APP_PORT=3000
APP_ENV=production
APP_SECRET=troque_por_secret_forte_aqui

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=whatsapp
POSTGRES_PASSWORD=whatsapp_secret
POSTGRES_DB=whatsapp_bitrix
POSTGRES_SSLMODE=disable
POSTGRES_MAX_OPEN_CONNS=50
POSTGRES_MAX_IDLE_CONNS=10

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0

# ─── WhatsApp ────────────────────────────────────────────────────────────────
WA_SESSIONS_DIR=./sessions
WA_MEDIA_DIR=./media
WA_LOG_LEVEL=INFO

# ─── Bitrix24 ────────────────────────────────────────────────────────────────
BITRIX_DOMAIN=https://suaempresa.bitrix24.com.br
BITRIX_CLIENT_ID=seu_client_id
BITRIX_CLIENT_SECRET=seu_client_secret
BITRIX_REDIRECT_URI=https://seuservidor.com/bitrix/callback

# ─── Fila ────────────────────────────────────────────────────────────────────
QUEUE_WORKERS=20
QUEUE_MAX_RETRY=5
QUEUE_RETRY_BASE_DELAY_MS=1000

# ─── Watchdog ────────────────────────────────────────────────────────────────
WATCHDOG_PING_INTERVAL_SECS=30
